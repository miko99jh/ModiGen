model PlatinumResistor "Model of a platinum resistor" parameter Real R0 = 100 "Reference resistance at 0°C [ohm]"; parameter Real A = 3.9083*10^(-3) "Coefficient at 0°C"; parameter Real B = -5.775*10^(-7) "Coefficient at 0°C"; parameter Real C = -4.183*10^(-12) "Coefficient at 0°C"; Real T "Current temperature [K]"; Real Rt "Resistance value [ohm]"; equation Rt = Rt_T(T); end PlatinumResistor;